# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://multistream:password@localhost:5432/multistream"
DB_PASSWORD="password"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-string"
NEXTAUTH_SECRET="change-this-too"
NEXTAUTH_URL="http://localhost:4000"

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT="http://localhost:9000"        # internal  (Docker: http://minio:9000)
MINIO_PUBLIC_URL="http://localhost:9000"      # browser-accessible (= server IP in prod)
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
S3_BUCKET="openstream"
# AWS S3 (leave blank to use MinIO)
AWS_ACCESS_KEY=""
AWS_SECRET_KEY=""
AWS_REGION="us-east-1"

# ── FFmpeg ────────────────────────────────────────────────────────────────────
# true  = run ffmpeg via docker run (no local install needed for dev)
# false = use ffmpeg from PATH / baked into container
FFMPEG_USE_DOCKER=true

# ── RTMP / SRS ────────────────────────────────────────────────────────────────
RTMP_SERVER_URL="rtmp://localhost:1935/live"
SRS_API_URL="http://localhost:1985"
NEXT_PUBLIC_RTMP_SERVER="rtmp://localhost:1935/live"
NEXT_PUBLIC_SRS_HTTP_URL="http://localhost:8080"

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:4000"
API_PORT=4001
API_URL="http://localhost:4001"
NEXT_PUBLIC_API_URL="http://localhost:4001"

# ── OAuth ─────────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# ── LiveKit (optional browser studio backend) ─────────────────────────────────
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL=""
NEXT_PUBLIC_LIVEKIT_URL=""
